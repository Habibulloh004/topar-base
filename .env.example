# Docker Compose env (root)
#
# Network where your already-running mongodb container exists.
# Use: docker network ls
MONGO_DOCKER_NETWORK=topar_topar-network

# Mongo URI for backend container to connect to docker mongodb.
# Host should be mongodb container/service name on that network.
MONGODB_URI_DOCKER=mongodb://topar_admin:topar_password_2024@mongodb:27017/topar_db?authSource=admin

# Dashboard build-time API URL
VITE_API_BASE_URL=/api

# Redis cache settings for backend container
REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=0
