PORT=8080
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=topar_db
# Optional absolute/relative path override for categories JSON
# CATEGORIES_FILE=../chitai-gorod-categories.json
# Uploads root directory (served under /uploads)
UPLOADS_DIR=./uploads

# Redis response cache
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# Supports duration format (e.g. 30s, 2m). Use 0 for no expiry (until invalidation).
REDIS_CACHE_TTL=0

# Eksmo products sync API configuration
EKSMO_API_KEY=1c9f4b81fe6534532db07fa1fefabb0c
# Comma-separated list; when set, products sync pulls from all keys.
EKSMO_API_KEYS=1c9f4b81fe6534532db07fa1fefabb0c,1f7fab12215b7d85c62d2492ed66750d
EKSMO_BASE_URL=https://api3.eksmo.ru
EKSMO_PER_PAGE=500
# 0 = no page limit, sync all pages in one call
EKSMO_MAX_PAGES=0
EKSMO_TIMEOUT_SECONDS=300
EKSMO_RETRIES=6
EKSMO_BACKOFF_MS=1500

# Billz -> Main Products sync
BILLZ_SYNC_ENABLED=true
BILLZ_AUTH_URL=https://api-admin.billz.ai/v1/auth
BILLZ_URL=https://api-admin.billz.ai/v2
BILLZ_API_SECRET_KEY=your_billz_secret_token
BILLZ_TARGET_SHOP=topar
BILLZ_TIMEOUT_SECONDS=60
# Supports duration format (e.g. 1h, 5m, 300s)
BILLZ_SYNC_INTERVAL=1h
